# Brickset API — get a free key at https://brickset.com/api/register
BRICKSET_API_KEY=""

# BrickEconomy API (optional, personal use only)
# BRICKECONOMY_API_KEY=""

# ── Value-refresh batch (scripts/refresh-values.mjs) — see docs/deploy-batch.md ──
# BrickLink Store API (OAuth 1.0a). Consumer key/secret are account-level; the token pair is
# IP-bound — use the token registered for the machine that runs the batch (the static-IP box,
# not home). The script reads these from .env.local at the repo root.
BL_CONSUMER_KEY=""
BL_CONSUMER_SECRET=""
BL_TOKEN=""
BL_TOKEN_SECRET=""

# Upstash Redis REST (same store as cloud sync) — where the batch writes value:SET / history:SET.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

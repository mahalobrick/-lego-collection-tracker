# Dependencies
node_modules/

# Build output
dist/

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# Backup files (pre-git version control)
src/*.before-*.jsx
src/*.stable-*.jsx
src/*.backup.jsx
src-backup-before-budget/
api/*.before-*.js

# Personal data files
collection.json
*.csv
# ...but the Rebrickable catalog shipped with the app MUST deploy (used by the
# in-browser catalog loader at /sets.csv and /themes.csv):
!public/sets.csv
!public/themes.csv
# ...and committed value-source evidence under docs/ is durable, not scratch:
!docs/evidence/bl-coverage-full.csv

# Claude-specific config
.claude/

# Build artifacts in public
public/assets/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Vercel
.vercel/
.env*

# Local data exports & full-collection backups — NEVER commit (private collection + cloud Upstash blob)
outputs/
